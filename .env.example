# =====================================================
# UserBank Gateway - 环境变量示例
# 拷贝为 .env 后再按需修改
# =====================================================

# ----- HTTP 服务 -----
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ----- 下游 RAG Core 服务 -----
# userbank-rag-core 的检索服务地址
RAG_CORE_BASE_URL=http://127.0.0.1:9000
RAG_CORE_TIMEOUT_MS=15000
RAG_CORE_TOP_K=5

# ----- LLM Provider -----
# 目前仅实现 openai (兼容 OpenAI Chat Completions 协议: OpenAI / Azure OpenAI / LlamaEdge / vLLM 等)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=30000
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ----- 业务参数 -----
# Prompt 中允许放入的最大 citation 字符数（用于截断防爆 context）
PROMPT_MAX_CONTEXT_CHARS=6000

# ----- 预留扩展点 -----
# 鉴权 / 多租户 / 流式：MVP 不启用
AUTH_ENABLED=false
